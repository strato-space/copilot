#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Links an object manifest to an artifact record it describes.
# not: Not a patch relation.
# why: Makes artifact context selection explicit.
relation object_manifest_describes_artifact_record,
  relates object_manifest,
  relates manifested_artifact_record;
# --- </semantic-card> ---


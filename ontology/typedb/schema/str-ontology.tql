# --- <to_be> ---
# --- <to-be.semantic-core> ---
# Initial target-state semantic core aligned to Mode Engine, object-bound lifecycle, SemanticCards, and per-project AFS semantics.

# --- <semantic-card id="project_context_card"> ---
# kind: bounded-context-surface
# fpf_basis:
#   - U.BoundedContext
#   - E.17 U.MultiViewDescribing
# scope: BC.ProjectWorld
# what: Stable semantic entrypoint for one project.
# not: Not a raw project row or routing template.
# why: Provides one canonical project surface for reasoning, packs, policy, and ontology inheritance.
entity project_context_card,
  owns project_context_card_id @key,
  owns project_id,
  owns name,
  owns summary,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays project_context_card_describes_project:project_context_card,
  plays project_context_card_concerns_system_of_interest:project_context_card,
  plays project_context_card_within_producing_system:project_context_card,
  plays project_context_card_binds_context_pack:project_context_card,
  plays object_revision_revises_project_context_card:revised_project_context_card,
  plays object_note_attaches_to_project_context_card:noted_project_context_card,
  plays object_conclusion_applies_to_project_context_card:concluded_project_context_card;
# --- </semantic-card> ---

# --- <semantic-card id="system_of_interest"> ---
# kind: system-of-interest
# fpf_basis:
#   - A.1 U.Entity
#   - A.6.3 U.EpistemicViewing
# scope: BC.ProductWorld
# what: The thing being changed, described, or evaluated on the product side.
# not: Not the producing system and not the project container.
# why: Prevents product claims from collapsing into project-management objects.
entity system_of_interest,
  owns system_of_interest_id @key,
  owns name,
  owns summary,
  owns status @values("identified", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays project_context_card_concerns_system_of_interest:system_of_interest,
  plays goal_product_targets_system_of_interest:system_of_interest,
  plays task_changes_system_of_interest:changed_system_of_interest;
# --- </semantic-card> ---

# --- <semantic-card id="producing_system"> ---
# kind: producing-system
# fpf_basis:
#   - A.1 U.System
# scope: BC.ProcessWorld
# what: The socio-technical system that executes tasks and produces outputs.
# not: Not the product/system being changed.
# why: Separates the producer from the object of change.
entity producing_system,
  owns producing_system_id @key,
  owns name,
  owns summary,
  owns status @values("identified", "active", "degraded", "retired"),
  owns created_at,
  owns updated_at,
  plays project_context_card_within_producing_system:producing_system,
  plays goal_process_targets_producing_system:producing_system,
  plays task_executed_by_producing_system:executing_producing_system;
# --- </semantic-card> ---

# --- <semantic-card id="agent_role"> ---
# kind: role-taxon
# fpf_basis:
#   - A.2 Role Taxonomy
#   - A.2.1 U.RoleAssignment
# scope: BC.AgentWorld
# what: Named responsibility profile used by agents.
# not: Not a workflow or runtime worker instance.
# why: Separates role semantics from execution mechanics.
entity agent_role,
  owns agent_role_id @key,
  owns name,
  owns description,
  owns role_name,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays agent_role_executes_prompt_pipeline:agent_role;
# --- </semantic-card> ---

# --- <semantic-card id="prompt_pipeline"> ---
# kind: workflow-definition
# fpf_basis:
#   - C.Agent-Tools-CAL
# scope: BC.AgentWorld
# what: Reusable prompt/workflow definition.
# not: Not a single run or mode segment.
# why: Makes durable prompt logic queryable and reviewable.
entity prompt_pipeline,
  owns prompt_pipeline_id @key,
  owns name,
  owns description,
  owns source_ref,
  owns module_scope,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays agent_role_executes_prompt_pipeline:prompt_pipeline;
# --- </semantic-card> ---

# --- <semantic-card id="coding_agent"> ---
# kind: coding-agent
# fpf_basis:
#   - C.Agent-Tools-CAL
#   - A.2.2 U.Capability
# scope: BC.AgentWorld
# what: Executable CLI/agent surface used to perform coding work.
# not: Not a role taxonomy, not a prompt definition, and not a single run occurrence.
# why: Separates durable execution surfaces from roles, prompts, and runtime events.
entity coding_agent,
  owns coding_agent_id @key,
  owns name,
  owns summary,
  owns executable_path,
  owns cli_arguments,
  owns working_directory,
  owns source_ref,
  owns status @values("enabled", "disabled", "degraded", "retired"),
  owns created_at,
  owns updated_at,
  plays coding_agent_enacts_agent_role:coding_agent,
  plays coding_agent_uses_prompt_pipeline:coding_agent,
  plays coding_agent_enacts_executor_role:coding_agent,
  plays coding_agent_supports_task_family:coding_agent,
  plays task_recommended_for_coding_agent:recommended_coding_agent;
# --- </semantic-card> ---

# --- <semantic-card id="executor_role"> ---
# kind: executor-role
# fpf_basis:
#   - A.2 Role Taxonomy
# scope: BC.AgentWorld
# what: Capability-side role used for routing tasks to human or machine executors.
# not: Not the task family and not a concrete executor instance.
# why: Keeps executor capability semantics separate from task classification.
entity executor_role,
  owns executor_role_id @key,
  owns name,
  owns summary,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays coding_agent_enacts_executor_role:executor_role,
  plays performer_profile_enacts_executor_role:executor_role,
  plays task_family_eligible_for_executor_role:eligible_executor_role;
# --- </semantic-card> ---

# --- <semantic-card id="task_family"> ---
# kind: task-family
# fpf_basis:
#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Practical task classification family used for routing and capability matching.
# not: Not the executor role and not the task itself.
# why: Keeps task segmentation explicit for routing and bootstrap agent specialization.
entity task_family,
  owns task_family_id @key,
  owns name,
  owns summary,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays task_classified_as_task_family:task_family,
  plays coding_agent_supports_task_family:supported_task_family,
  plays task_family_eligible_for_executor_role:task_family,
  plays executor_routing_classifies_task_family:task_family;
# --- </semantic-card> ---

# --- <semantic-card id="mode_definition"> ---
# kind: mode-definition
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ModeEngineWorld
# what: Reusable Mode Engine definition.
# not: Not a session and not a segment.
# why: Holds stable mode semantics, budgets, and expected outputs.
entity mode_definition,
  owns mode_definition_id @key,
  owns name,
  owns description,
  owns module_scope,
  owns status,
  owns created_at,
  owns updated_at,
  plays mode_segment_uses_mode_definition:mode_definition,
  plays mode_definition_emits_output_contract:mode_definition,
  plays context_pack_supports_mode_definition:supported_mode_definition;
# --- </semantic-card> ---

# --- <semantic-card id="mode_segment"> ---
# kind: mode-segment
# fpf_basis:
#   - U.BoundedContext
#   - A.6.5 U.RelationSlotDiscipline
# scope: BC.ModeEngineWorld
# what: Bounded interval of a session under one active mode.
# not: Not the whole session.
# why: Preserves traceability when mode or scope changes.
entity mode_segment,
  owns mode_segment_id @key,
  owns session_id,
  owns source_ref,
  owns status,
  owns created_at,
  owns updated_at,
  plays mode_segment_uses_mode_definition:mode_segment,
  plays mode_segment_has_interaction_scope:mode_segment,
  plays mode_segment_uses_aggregation_window:mode_segment,
  plays mode_segment_uses_context_pack:mode_segment,
  plays context_bundle_assembles_mode_segment:mode_segment,
  plays object_revision_revises_mode_segment:revised_mode_segment,
  plays object_event_affects_mode_segment:affected_mode_segment,
  plays as_is_voice_session_maps_to_mode_segment:mode_segment;
# --- </semantic-card> ---

# --- <semantic-card id="interaction_scope"> ---
# kind: scope-definition
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ModeEngineWorld
# what: Named interaction shape such as personal or group.
# not: Not a permission policy.
# why: Makes conversational format explicit in reasoning.
entity interaction_scope,
  owns interaction_scope_id @key,
  owns name,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays mode_segment_has_interaction_scope:interaction_scope;
# --- </semantic-card> ---

# --- <semantic-card id="aggregation_window"> ---
# kind: aggregation-policy
# fpf_basis:
#   - A.6 Signature Stack
# scope: BC.ModeEngineWorld
# what: Window used to aggregate chunks before output.
# not: Not a transcript chunk.
# why: Makes output granularity explicit and auditable.
entity aggregation_window,
  owns aggregation_window_id @key,
  owns name,
  owns summary,
  owns duration_ms,
  owns status,
  owns created_at,
  owns updated_at,
  plays mode_segment_uses_aggregation_window:aggregation_window;
# --- </semantic-card> ---

# --- <semantic-card id="context_pack"> ---
# kind: context-pack
# fpf_basis:
#   - U.BoundedContext
#   - E.17 U.MultiViewDescribing
# scope: BC.ModeEngineWorld
# what: Curated package of context sources.
# not: Not the whole project memory.
# why: Makes context selection reusable and bounded.
entity context_pack,
  owns context_pack_id @key,
  owns project_id,
  owns source_ref,
  owns name,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays mode_segment_uses_context_pack:context_pack,
  plays context_pack_supports_mode_definition:context_pack,
  plays project_context_card_binds_context_pack:bound_context_pack;
# --- </semantic-card> ---

# --- <semantic-card id="output_contract"> ---
# kind: contract-surface
# fpf_basis:
#   - A.2.3 U.PromiseContent
#   - A.6.C Contract Unpacking
# scope: BC.ModeEngineWorld
# what: Declared output surface and operational expectations.
# not: Not the artifact itself.
# why: Separates promised output from artifact instances and gates.
entity output_contract,
  owns output_contract_id @key,
  owns name,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays mode_definition_emits_output_contract:output_contract,
  plays output_contract_promises_content:output_contract,
  plays output_contract_uses_admissibility_gate:output_contract,
  plays output_contract_uses_writeback_gate:output_contract,
  plays output_contract_targets_artifact_record:output_contract,
  plays context_bundle_realizes_output_contract:output_contract;
# --- </semantic-card> ---

# --- <semantic-card id="promise_content"> ---
# kind: promise-clause
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ModeEngineWorld
# what: Semantic payload promised by an output contract.
# not: Not a gate or transport wrapper.
# why: Aligns output semantics with FPF PromiseContent.
entity promise_content,
  owns promise_content_id @key,
  owns name,
  owns description,
  owns status,
  owns created_at,
  owns updated_at,
  plays output_contract_promises_content:promise_content;
# --- </semantic-card> ---

# --- <semantic-card id="admissibility_gate"> ---
# kind: admissibility-gate
# fpf_basis:
#   - A.6 Signature Stack
# scope: BC.ModeEngineWorld
# what: Gate deciding whether an output may be emitted.
# not: Not the output content.
# why: Separates admissibility from promised content.
entity admissibility_gate,
  owns admissibility_gate_id @key,
  owns name,
  owns description,
  owns status,
  owns created_at,
  owns updated_at,
  plays output_contract_uses_admissibility_gate:admissibility_gate;
# --- </semantic-card> ---

# --- <semantic-card id="writeback_gate"> ---
# kind: writeback-gate
# fpf_basis:
#   - A.2.8 U.Commitment
#   - A.2.9 U.SpeechAct
# scope: BC.ModeEngineWorld
# what: Gate deciding whether output may be written back.
# not: Not the writeback decision itself.
# why: Makes writeback policy explicit.
entity writeback_gate,
  owns writeback_gate_id @key,
  owns name,
  owns description,
  owns status,
  owns created_at,
  owns updated_at,
  plays output_contract_uses_writeback_gate:writeback_gate;
# --- </semantic-card> ---

# --- <semantic-card id="artifact_record"> ---
# kind: semantic-artifact
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Durable semantic artifact object.
# not: Not a raw file blob or generic memory item.
# why: Gives outputs stable identity and lineage.
entity artifact_record,
  owns artifact_record_id @key,
  owns project_id,
  owns source_type,
  owns source_ref,
  owns external_ref,
  owns title,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays artifact_record_supports_project:artifact_record,
  plays artifact_patch_updates_artifact_record:artifact_record,
  plays output_contract_targets_artifact_record:artifact_record,
  plays task_produces_artifact_record:produced_artifact_record,
  plays task_execution_run_produces_artifact_record:produced_artifact_record,
  plays object_revision_revises_artifact_record:revised_artifact_record,
  plays object_event_affects_artifact_record:affected_artifact_record,
  plays object_note_attaches_to_artifact_record:noted_artifact_record,
  plays object_conclusion_applies_to_artifact_record:concluded_artifact_record,
  plays object_manifest_describes_artifact_record:manifested_artifact_record,
  plays as_is_attachment_maps_to_artifact_record:artifact_record;
# --- </semantic-card> ---

# --- <semantic-card id="artifact_patch"> ---
# kind: artifact-patch
# fpf_basis:
#   - A.6.S U.SignatureEngineeringPair
# scope: BC.ArtifactWorld
# what: Versioned update applied to an artifact record.
# not: Not the artifact itself.
# why: Captures patch-aware evolution of artifacts.
entity artifact_patch,
  owns artifact_patch_id @key,
  owns source_ref,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays artifact_patch_updates_artifact_record:artifact_patch;
# --- </semantic-card> ---

# --- <semantic-card id="context_bundle"> ---
# kind: context-bundle
# fpf_basis:
#   - U.BoundedContext
#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Assembled context package for one reasoning act.
# not: Not a raw session or memory store.
# why: Makes context assembly inspectable and reproducible.
entity context_bundle,
  owns context_bundle_id @key,
  owns project_id,
  owns source_type,
  owns source_ref,
  owns name,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays context_bundle_assembles_project:context_bundle,
  plays context_bundle_assembles_mode_segment:context_bundle,
  plays context_bundle_assembles_task:context_bundle,
  plays context_bundle_realizes_output_contract:context_bundle,
  plays object_manifest_assembled_for_context_bundle:context_bundle,
  plays access_policy_governs_context_bundle:context_bundle;
# --- </semantic-card> ---

# --- <semantic-card id="executor_routing"> ---
# kind: executor-routing
# fpf_basis:
#   - A.2.9 U.SpeechAct
#   - C.Agent-Tools-CAL
# scope: BC.TaskWorld
# what: Durable routing decision from one task to an executor contour.
# not: Not the execution run itself and not a generic UI suggestion.
# why: Makes routing proposals and approvals explicit and auditable.
entity executor_routing,
  owns executor_routing_id @key,
  owns selected_executor_kind @values("human", "coding_agent", "mixed"),
  owns selected_executor_ref,
  owns routing_basis,
  owns approval_state @values("pending", "approved", "rejected", "superseded"),
  owns launch_state @values("not_ready", "ready", "launched", "failed", "cancelled"),
  owns summary,
  owns status @values("proposed", "approved", "rejected", "launched", "superseded"),
  owns created_at,
  owns updated_at,
  plays executor_routing_targets_task:executor_routing,
  plays executor_routing_classifies_task_family:executor_routing,
  plays executor_routing_launches_task_execution_run:executor_routing;
# --- </semantic-card> ---

# --- <semantic-card id="task_execution_run"> ---
# kind: task-execution-run
# fpf_basis:
#   - C.Agent-Tools-CAL
#   - A.2.9 U.SpeechAct
# scope: BC.TaskWorld
# what: One execution occurrence of one task by one executor contour.
# not: Not a voice processing run and not a routing proposal.
# why: Separates task execution from extraction/runtime processing.
entity task_execution_run,
  owns task_execution_run_id @key,
  owns executor_kind @values("human", "coding_agent", "mixed"),
  owns executor_ref,
  owns result_ref,
  owns source_ref,
  owns summary,
  owns status @values("queued", "running", "succeeded", "failed", "cancelled"),
  owns started_at,
  owns ended_at,
  owns created_at,
  owns updated_at,
  plays executor_routing_launches_task_execution_run:launched_task_execution_run,
  plays task_execution_run_executes_task:task_execution_run,
  plays task_execution_run_produces_artifact_record:task_execution_run;
# --- </semantic-card> ---

# --- <semantic-card id="goal_process"> ---
# kind: process-goal
# fpf_basis:
#   - A.1 U.Entity
# scope: BC.ProcessWorld
# what: Desired outcome of the producing system or delivery process.
# not: Not a product requirement and not a task.
# why: Separates process outcomes from product outcomes.
entity goal_process,
  owns goal_process_id @key,
  owns title,
  owns summary,
  owns status @values("draft", "active", "satisfied", "superseded", "cancelled"),
  owns created_at,
  owns updated_at,
  plays goal_process_targets_producing_system:goal_process,
  plays goal_process_decomposes_to_task:goal_process,
  plays goal_process_measured_by_kpi:goal_process;
# --- </semantic-card> ---

# --- <semantic-card id="goal_product"> ---
# kind: product-goal
# fpf_basis:
#   - A.1 U.Entity
# scope: BC.ProductWorld
# what: Desired product outcome for the system of interest.
# not: Not a task and not a process outcome.
# why: Separates product telos from delivery work.
entity goal_product,
  owns goal_product_id @key,
  owns title,
  owns summary,
  owns status @values("draft", "active", "satisfied", "superseded", "cancelled"),
  owns created_at,
  owns updated_at,
  plays goal_product_targets_system_of_interest:goal_product,
  plays business_need_drives_goal_product:goal_product,
  plays goal_product_decomposes_to_requirement:goal_product,
  plays goal_product_measured_by_kpi:goal_product;
# --- </semantic-card> ---

# --- <semantic-card id="business_need"> ---
# kind: business-need
# fpf_basis:
#   - A.1 U.Entity
# scope: BC.ProductWorld
# what: The initiating problem/opportunity that justifies the work.
# not: Not a requirement and not a task.
# why: Keeps justification distinct from implementation.
entity business_need,
  owns business_need_id @key,
  owns title,
  owns summary,
  owns status @values("identified", "active", "satisfied", "superseded", "cancelled"),
  owns created_at,
  owns updated_at,
  plays business_need_drives_goal_product:business_need;
# --- </semantic-card> ---

# --- <semantic-card id="requirement"> ---
# kind: requirement
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ProductWorld
# what: A condition/property the system of interest must satisfy.
# not: Not a task and not a business need.
# why: Makes product obligations explicit.
entity requirement,
  owns requirement_id @key,
  owns title,
  owns summary,
  owns status @values("draft", "approved", "satisfied", "superseded", "cancelled"),
  owns created_at,
  owns updated_at,
  plays goal_product_decomposes_to_requirement:requirement,
  plays task_satisfies_requirement:satisfied_requirement;
# --- </semantic-card> ---

# --- <semantic-card id="acceptance_criterion"> ---
# kind: acceptance-criterion
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ArtifactWorld
# what: A typed criterion against which a produced result is accepted or rejected.
# not: Not the result itself and not the evaluation event.
# why: Separates the standard of acceptance from the artifact and verdict.
entity acceptance_criterion,
  owns acceptance_criterion_id @key,
  owns title,
  owns summary,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at,
  plays task_must_satisfy_acceptance_criterion:acceptance_criterion,
  plays acceptance_evaluation_checks_acceptance_criterion:acceptance_criterion;
# --- </semantic-card> ---

# --- <semantic-card id="acceptance_evaluation"> ---
# kind: acceptance-evaluation
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.ArtifactWorld
# what: One acceptance verdict over one produced artifact against one criterion.
# not: Not the criterion and not the artifact itself.
# why: Separates acceptance judgment from both artifact and rule.
entity acceptance_evaluation,
  owns acceptance_evaluation_id @key,
  owns summary,
  owns status @values("pending", "passed", "failed", "waived"),
  owns created_at,
  owns updated_at,
  plays acceptance_evaluation_checks_acceptance_criterion:acceptance_evaluation,
  plays acceptance_evaluation_evaluates_artifact_record:acceptance_evaluation;
# --- </semantic-card> ---

# --- <semantic-card id="evidence_link"> ---
# kind: evidence-link
# fpf_basis:
#   - A.10 EvidenceGraph Referring
# scope: BC.TraceWorld
# what: Normalized evidence carrier for a quote/span/source that justifies a task.
# not: Not the task/session link itself.
# why: Keeps quoted evidence first-class without inflating session membership into an entity.
entity evidence_link,
  owns evidence_link_id @key,
  owns source_ref,
  owns summary,
  owns description,
  owns status,
  owns created_at,
  owns updated_at,
  plays task_cites_evidence_link:evidence_link,
  plays visual_observation_cites_evidence_link:evidence_link;
# --- </semantic-card> ---

# --- <semantic-card id="evidence_observation"> ---
# kind: evidence-observation
# fpf_basis:
#   - A.10 EvidenceGraph Referring
# scope: BC.TraceWorld
# what: Base evidence-side observation entity derived from source traces.
# not: Not a task and not an epistemic assumption.
# why: Separates evidence observations from domain and epistemic claims.
entity evidence_observation,
  owns evidence_observation_id @key,
  owns source_ref,
  owns summary,
  owns description,
  owns status @values("draft", "active", "superseded", "retired"),
  owns created_at,
  owns updated_at;
# --- </semantic-card> ---

# --- <semantic-card id="visual_observation"> ---
# kind: visual-observation
# fpf_basis:
#   - A.10 EvidenceGraph Referring
# scope: BC.TraceWorld
# what: Evidence observation specific to UI/screen/layout visual facts.
# not: Not a product requirement and not a task instruction.
# why: Makes visual evidence first-class and queryable.
entity visual_observation sub evidence_observation,
  owns observation_type @values("layout", "style", "content", "interaction", "other"),
  plays visual_observation_cites_evidence_link:visual_observation,
  plays visual_observation_about_object_locator:visual_observation;
# --- </semantic-card> ---

# --- <semantic-card id="reasoning_item"> ---
# kind: epistemic-item
# fpf_basis:
#   - A.6.3 U.EpistemicViewing
# scope: BC.ProcessWorld
# what: Base epistemic statement captured during analysis/planning.
# not: Not direct evidence and not executable task state.
# why: Prevents epistemic claims from collapsing into domain objects.
entity reasoning_item,
  owns reasoning_item_id @key,
  owns project_id,
  owns source_ref,
  owns summary,
  owns reasoning_kind @values("assumption", "open_question", "unknown"),
  owns assertion_status @values("stated", "validated", "invalidated", "superseded"),
  owns status @values("open", "closed", "superseded", "retired"),
  owns created_at,
  owns updated_at;
# --- </semantic-card> ---

# --- <semantic-card id="assumption"> ---
# kind: assumption
# fpf_basis:
#   - A.6.3 U.EpistemicViewing
# scope: BC.ProcessWorld
# what: Defeasible assumption conditioning delivery decisions.
# not: Not a requirement and not confirmed evidence.
# why: Makes planning assumptions explicit and testable.
entity assumption sub reasoning_item,
  owns confidence @values("low", "medium", "high"),
  plays assumption_conditions_task:assumption;
# --- </semantic-card> ---

# --- <semantic-card id="open_question"> ---
# kind: open-question
# fpf_basis:
#   - A.6.3 U.EpistemicViewing
# scope: BC.ProcessWorld
# what: Explicit unresolved question blocking or constraining execution.
# not: Not a resolved decision and not a task itself.
# why: Captures uncertainty as first-class planning object.
entity open_question sub reasoning_item,
  owns question_kind @values("scope", "risk", "requirement", "execution", "other"),
  plays open_question_blocks_task:open_question;
# --- </semantic-card> ---

# --- <semantic-card id="object_revision"> ---
# kind: history-revision
# fpf_basis:
#   - A.6.S U.SignatureEngineeringPair
# scope: BC.ArtifactWorld
# what: Revision record attached to one object.
# not: Not a global history bucket.
# why: Supports current-state plus explicit history access.
entity object_revision,
  owns object_revision_id @key,
  owns source_ref,
  owns row_version,
  owns status,
  owns created_at,
  owns updated_at,
  plays object_revision_revises_project_context_card:object_revision,
  plays object_revision_revises_mode_segment:object_revision,
  plays object_revision_revises_task:object_revision,
  plays object_revision_revises_artifact_record:object_revision;
# --- </semantic-card> ---

# --- <semantic-card id="object_event"> ---
# kind: history-event
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.ArtifactWorld
# what: Event attached to one object.
# not: Not a detached audit blob.
# why: Captures object-level change history with provenance.
entity object_event,
  owns object_event_id @key,
  owns event_time,
  owns operation_type,
  owns source_ref,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays object_event_affects_mode_segment:object_event,
  plays object_event_affects_task:object_event,
  plays object_event_affects_artifact_record:object_event,
  plays as_is_voice_message_maps_to_object_event:object_event;
# --- </semantic-card> ---

# --- <semantic-card id="object_note"> ---
# kind: object-note
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.ArtifactWorld
# what: Human or agent note attached to one object.
# not: Not free-floating memory.
# why: Lets notes stay object-bound and queryable.
entity object_note,
  owns object_note_id @key,
  owns notes,
  owns source_ref,
  owns status,
  owns created_at,
  owns updated_at,
  plays object_note_attaches_to_project_context_card:object_note,
  plays object_note_attaches_to_task:object_note,
  plays object_note_attaches_to_artifact_record:object_note,
  plays writeback_decision_writes_object_note:object_note;
# --- </semantic-card> ---

# --- <semantic-card id="object_conclusion"> ---
# kind: object-conclusion
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Interpreted conclusion attached to one object.
# not: Not a raw summary text.
# why: Separates interpreted state from raw event history.
entity object_conclusion,
  owns object_conclusion_id @key,
  owns summary,
  owns description,
  owns source_ref,
  owns status,
  owns created_at,
  owns updated_at,
  plays object_conclusion_applies_to_project_context_card:object_conclusion,
  plays object_conclusion_applies_to_task:object_conclusion,
  plays object_conclusion_applies_to_artifact_record:object_conclusion,
  plays as_is_summary_maps_to_object_conclusion:object_conclusion;
# --- </semantic-card> ---

# --- <semantic-card id="object_manifest"> ---
# kind: context-manifest
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Manifest describing selected and excluded context.
# not: Not the context bundle itself.
# why: Makes context assembly explainable and auditable.
entity object_manifest,
  owns object_manifest_id @key,
  owns source_ref,
  owns summary,
  owns status,
  owns created_at,
  owns updated_at,
  plays object_manifest_describes_artifact_record:object_manifest,
  plays object_manifest_assembled_for_context_bundle:object_manifest;
# --- </semantic-card> ---

# --- <semantic-card id="change_proposal"> ---
# kind: change-proposal
# fpf_basis:
#   - A.2.9 U.SpeechAct
#   - A.2.8 U.Commitment
# scope: BC.ArtifactWorld
# what: Proposed mutation to an object before approval.
# not: Not the approved writeback order and not the patch itself.
# why: Separates proposed change intent from approval and execution.
entity change_proposal,
  owns change_proposal_id @key,
  owns source_ref,
  owns summary,
  owns description,
  owns status @values("proposed", "accepted", "rejected", "superseded"),
  owns created_at,
  owns updated_at,
  plays change_proposal_targets_task:change_proposal,
  plays writeback_decision_accepts_change_proposal:change_proposal;
# --- </semantic-card> ---

# --- <semantic-card id="writeback_decision"> ---
# kind: review-decision
# fpf_basis:
#   - A.2.8 U.Commitment
#   - A.2.9 U.SpeechAct
# scope: BC.ArtifactWorld
# what: Decision to write information back to an object.
# not: Not the note or conclusion itself.
# why: Separates policy and review from resulting state change.
entity writeback_decision,
  owns writeback_decision_id @key,
  owns source_ref,
  owns summary,
  owns status @values("pending", "approved", "rejected", "executed", "superseded"),
  owns created_at,
  owns updated_at,
  plays writeback_decision_accepts_change_proposal:writeback_decision,
  plays writeback_decision_writes_object_note:writeback_decision,
  plays review_annotation_approves_writeback:writeback_decision;
# --- </semantic-card> ---

# --- <semantic-card id="review_annotation"> ---
# kind: review-annotation
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.ArtifactWorld
# what: Approval or rejection annotation over a decision.
# not: Not the writeback itself.
# why: Makes human or agent review part of semantic trace.
entity review_annotation,
  owns review_annotation_id @key,
  owns comment,
  owns status @values("commented", "approved", "rejected", "superseded"),
  owns created_at,
  owns updated_at,
  plays review_annotation_approves_writeback:review_annotation;
# --- </semantic-card> ---

# --- <semantic-card id="access_policy"> ---
# kind: access-policy
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ArtifactWorld
# what: Policy governing access to a context bundle or object.
# not: Not a routing decision.
# why: Makes visibility and policy semantics explicit.
entity access_policy,
  owns access_policy_id @key,
  owns name,
  owns description,
  owns status,
  owns created_at,
  owns updated_at,
  plays access_policy_governs_context_bundle:access_policy;
# --- </semantic-card> ---

# --- <semantic-card id="project_context_card_describes_project"> ---
# kind: projection-relation
# fpf_basis:
#   - U.BoundedContext
#   - E.17 U.MultiViewDescribing
# scope: BC.ProjectWorld
# what: Connects the project semantic card to the project it describes.
# not: Not a routing or ownership relation.
# why: Makes one semantic card the canonical project-facing surface.
relation project_context_card_describes_project,
  relates project_context_card,
  relates described_project;
# --- </semantic-card> ---

# --- <semantic-card id="project_context_card_concerns_system_of_interest"> ---
# kind: projection-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProductWorld
# what: Links a project context card to the system of interest it concerns.
# not: Not project ownership.
# why: Prevents project/product conflation.
relation project_context_card_concerns_system_of_interest,
  relates project_context_card,
  relates system_of_interest;
# --- </semantic-card> ---

# --- <semantic-card id="project_context_card_within_producing_system"> ---
# kind: projection-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProcessWorld
# what: Links a project context card to the producing system within which work happens.
# not: Not the product/system being changed.
# why: Makes the producer explicit.
relation project_context_card_within_producing_system,
  relates project_context_card,
  relates producing_system;
# --- </semantic-card> ---

# --- <semantic-card id="agent_role_executes_prompt_pipeline"> ---
# kind: workflow-relation
# fpf_basis:
#   - A.2 Role Taxonomy
#   - C.Agent-Tools-CAL
# scope: BC.AgentWorld
# what: Links an agent role to a prompt pipeline it is allowed to execute.
# not: Not a runtime invocation record.
# why: Separates stable role/pipeline compatibility from one run.
relation agent_role_executes_prompt_pipeline,
  relates agent_role,
  relates prompt_pipeline;
# --- </semantic-card> ---

# --- <semantic-card id="coding_agent_enacts_agent_role"> ---
# kind: execution-relation
# fpf_basis:
#   - A.2 Role Taxonomy
# scope: BC.AgentWorld
# what: Links a coding agent runtime surface to the role it enacts.
# not: Not a prompt binding and not a task assignment.
# why: Separates executable agent identity from role taxonomy.
relation coding_agent_enacts_agent_role,
  relates coding_agent,
  relates agent_role;
# --- </semantic-card> ---

# --- <semantic-card id="coding_agent_uses_prompt_pipeline"> ---
# kind: execution-relation
# fpf_basis:
#   - C.Agent-Tools-CAL
# scope: BC.AgentWorld
# what: Links a coding agent runtime surface to the prompt pipeline it uses.
# not: Not a single run occurrence.
# why: Makes agent invocation semantics explicit and queryable.
relation coding_agent_uses_prompt_pipeline,
  relates coding_agent,
  relates prompt_pipeline;
# --- </semantic-card> ---

# --- <semantic-card id="coding_agent_enacts_executor_role"> ---
# kind: execution-relation
# fpf_basis:
#   - A.2 Role Taxonomy
# scope: BC.AgentWorld
# what: Links a coding agent to the executor role it can enact.
# not: Not a prompt binding.
# why: Separates executor capability role from tool identity.
relation coding_agent_enacts_executor_role,
  relates coding_agent,
  relates executor_role;
# --- </semantic-card> ---

# --- <semantic-card id="performer_profile_enacts_executor_role"> ---
# kind: execution-relation
# fpf_basis:
#   - A.2 Role Taxonomy
# scope: BC.AgentWorld
# what: Links a human performer profile to the executor role it can enact.
# not: Not a payroll or project-membership relation.
# why: Allows routing to use the same capability-side axis for humans and agents.
relation performer_profile_enacts_executor_role,
  relates performer_profile,
  relates executor_role;
# --- </semantic-card> ---

# --- <semantic-card id="coding_agent_supports_task_family"> ---
# kind: capability-relation
# fpf_basis:
#   - C.Agent-Tools-CAL
# scope: BC.TaskWorld
# what: Declares that a coding agent supports a given task family.
# not: Not a concrete routing decision.
# why: Makes capability matching explicit for executor routing.
relation coding_agent_supports_task_family,
  relates coding_agent,
  relates supported_task_family;
# --- </semantic-card> ---

# --- <semantic-card id="task_family_eligible_for_executor_role"> ---
# kind: capability-relation
# fpf_basis:
#   - A.2 Role Taxonomy
# scope: BC.TaskWorld
# what: Declares that a task family is eligible for a given executor role.
# not: Not a specific executor assignment.
# why: Separates family-level routing policy from concrete executor selection.
relation task_family_eligible_for_executor_role,
  relates task_family,
  relates eligible_executor_role;
# --- </semantic-card> ---

# --- <semantic-card id="mode_segment_uses_mode_definition"> ---
# kind: mode-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ModeEngineWorld
# what: Links a mode segment to the mode definition governing it.
# not: Not a session-level alias.
# why: Makes mode switches explicit.
relation mode_segment_uses_mode_definition,
  relates mode_segment,
  relates mode_definition;
# --- </semantic-card> ---

# --- <semantic-card id="mode_segment_has_interaction_scope"> ---
# kind: mode-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ModeEngineWorld
# what: Links a mode segment to its interaction scope.
# not: Not an ACL relation.
# why: Keeps personal/group semantics explicit.
relation mode_segment_has_interaction_scope,
  relates mode_segment,
  relates interaction_scope;
# --- </semantic-card> ---

# --- <semantic-card id="mode_segment_uses_aggregation_window"> ---
# kind: mode-relation
# fpf_basis:
#   - A.6 Signature Stack
# scope: BC.ModeEngineWorld
# what: Links a mode segment to the aggregation window it uses.
# not: Not a timer event.
# why: Makes output granularity explicit.
relation mode_segment_uses_aggregation_window,
  relates mode_segment,
  relates aggregation_window;
# --- </semantic-card> ---

# --- <semantic-card id="mode_segment_uses_context_pack"> ---
# kind: context-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ModeEngineWorld
# what: Links a mode segment to a permitted context pack.
# not: Not evidence that every source in the pack was consumed.
# why: Separates allowed context from assembled context.
relation mode_segment_uses_context_pack,
  relates mode_segment,
  relates context_pack;
# --- </semantic-card> ---

# --- <semantic-card id="mode_definition_emits_output_contract"> ---
# kind: contract-relation
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ModeEngineWorld
# what: Links a mode definition to an output contract it emits.
# not: Not the output artifact itself.
# why: Makes delivery obligations explicit.
relation mode_definition_emits_output_contract,
  relates mode_definition,
  relates output_contract;
# --- </semantic-card> ---

# --- <semantic-card id="output_contract_promises_content"> ---
# kind: contract-relation
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ModeEngineWorld
# what: Links an output contract to the semantic payload it promises.
# not: Not an admissibility check.
# why: Separates promise from gating.
relation output_contract_promises_content,
  relates output_contract,
  relates promise_content;
# --- </semantic-card> ---

# --- <semantic-card id="output_contract_uses_admissibility_gate"> ---
# kind: gate-relation
# fpf_basis:
#   - A.6 Signature Stack
# scope: BC.ModeEngineWorld
# what: Links an output contract to its admissibility gate.
# not: Not writeback.
# why: Separates acceptance from persistence.
relation output_contract_uses_admissibility_gate,
  relates output_contract,
  relates admissibility_gate;
# --- </semantic-card> ---

# --- <semantic-card id="output_contract_uses_writeback_gate"> ---
# kind: gate-relation
# fpf_basis:
#   - A.2.8 U.Commitment
#   - A.2.9 U.SpeechAct
# scope: BC.ModeEngineWorld
# what: Links an output contract to its writeback gate.
# not: Not the writeback decision itself.
# why: Separates permission to write from the writeback event.
relation output_contract_uses_writeback_gate,
  relates output_contract,
  relates writeback_gate;
# --- </semantic-card> ---

# --- <semantic-card id="output_contract_targets_artifact_record"> ---
# kind: contract-relation
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ArtifactWorld
# what: Links an output contract to the artifact record it targets.
# not: Not the produced artifact patch.
# why: Keeps output destination explicit.
relation output_contract_targets_artifact_record,
  relates output_contract,
  relates artifact_record;
# --- </semantic-card> ---

# --- <semantic-card id="artifact_record_supports_project"> ---
# kind: artifact-relation
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Links an artifact record to the project it supports.
# not: Not simple file containment.
# why: Lets artifacts participate in project reasoning.
relation artifact_record_supports_project,
  relates artifact_record,
  relates supported_project;
# --- </semantic-card> ---

# --- <semantic-card id="artifact_patch_updates_artifact_record"> ---
# kind: lineage-relation
# fpf_basis:
#   - A.6.S U.SignatureEngineeringPair
# scope: BC.ArtifactWorld
# what: Links an artifact patch to the artifact record it updates.
# not: Not a writeback review relation.
# why: Captures artifact version lineage.
relation artifact_patch_updates_artifact_record,
  relates artifact_patch,
  relates artifact_record;
# --- </semantic-card> ---

# --- <semantic-card id="change_proposal_targets_task"> ---
# kind: proposal-relation

# kind: task-product-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProductWorld
# what: Links a task to the system of interest it changes or targets.
# not: Not execution ownership.
# why: Makes the product-side referent explicit.
relation task_changes_system_of_interest,
  relates task,
  relates changed_system_of_interest;
# --- </semantic-card> ---

# --- <semantic-card id="task_executed_by_producing_system"> ---
# kind: task-process-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProcessWorld
# what: Links a task to the producing system that executes it.
# not: Not the product target.
# why: Makes the producer explicit.
relation task_executed_by_producing_system,
  relates task,
  relates executing_producing_system;
# --- </semantic-card> ---


# kind: product-decomposition-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProductWorld
# what: Links a product goal to a requirement that decomposes it.
# not: Not process/task decomposition.
# why: Keeps requirement structure explicit.
relation goal_product_decomposes_to_requirement,
  relates goal_product,
  relates requirement;
# --- </semantic-card> ---


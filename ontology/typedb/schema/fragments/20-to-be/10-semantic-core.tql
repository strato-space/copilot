# what: Links a context bundle to the project context it assembles.
# not: Not a bridge from raw project rows.
# why: Keeps one reasoning act tied to one project context.
relation context_bundle_assembles_project,
  relates context_bundle,
  relates assembled_project;
# --- </semantic-card> ---

# --- <semantic-card id="context_bundle_assembles_mode_segment"> ---
# kind: context-relation
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ModeEngineWorld
# what: Links a context bundle to the mode segment it serves.
# not: Not a mode-definition relation.

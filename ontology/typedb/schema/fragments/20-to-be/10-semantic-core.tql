# kind: routing-relation
# fpf_basis:
#   - C.Agent-Tools-CAL
# scope: BC.TaskWorld
# what: Links a routing decision to the task it routes.
# not: Not the execution run itself.
# why: Makes task-to-routing lineage explicit.
relation executor_routing_targets_task,
  relates executor_routing,
  relates routed_task;
# --- </semantic-card> ---

# --- <semantic-card id="executor_routing_classifies_task_family"> ---
# kind: routing-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Records the task family used as routing basis.
# not: Not the executor identity.
# why: Preserves routing classification rationale.
relation executor_routing_classifies_task_family,
  relates executor_routing,
  relates task_family;

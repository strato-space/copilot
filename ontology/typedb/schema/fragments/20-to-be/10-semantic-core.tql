# kind: process-goal-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProcessWorld
# what: Links a process goal to the producing system it is about.
# not: Not a task decomposition.
# why: Keeps process goals bound to the producer.
relation goal_process_targets_producing_system,
  relates goal_process,
  relates producing_system;
# --- </semantic-card> ---

# --- <semantic-card id="goal_product_targets_system_of_interest"> ---
# kind: product-goal-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProductWorld
# what: Links a product goal to the system of interest it is about.
# not: Not a requirement decomposition.
# why: Keeps product goals bound to the thing being changed.
relation goal_product_targets_system_of_interest,
  relates goal_product,
  relates system_of_interest;
# --- </semantic-card> ---

# --- <semantic-card id="business_need_drives_goal_product"> ---
# kind: product-justification-relation
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProductWorld
# what: Links a business need to the product goal it drives.
# not: Not a task relation.
# why: Keeps product justification explicit.
relation business_need_drives_goal_product,
  relates business_need,
  relates goal_product;
# --- </semantic-card> ---


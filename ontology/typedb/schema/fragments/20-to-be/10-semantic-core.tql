#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Classifies a task into a practical task family.
# not: Not an executor selection.
# why: Makes task segmentation explicit for routing.
relation task_classified_as_task_family,
  relates task,
  relates task_family;

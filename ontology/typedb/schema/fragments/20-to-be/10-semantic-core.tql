relation context_bundle_assembles_task,
  relates context_bundle,
  relates assembled_task;
# --- </semantic-card> ---

# --- <semantic-card id="context_bundle_realizes_output_contract"> ---
# kind: contract-relation
# fpf_basis:
#   - A.6.C Contract Unpacking
# scope: BC.ModeEngineWorld
# what: Links a context bundle to the output contract realized in that reasoning act.
# not: Not a promise on its own.

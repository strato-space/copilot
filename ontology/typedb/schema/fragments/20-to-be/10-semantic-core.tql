# kind: acceptance-relation
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ArtifactWorld
# what: Links a task to the acceptance criterion governing its result.
# not: Not the verdict itself.
# why: Makes acceptance obligations explicit.
relation task_must_satisfy_acceptance_criterion,
  relates task,
  relates acceptance_criterion;
# --- </semantic-card> ---


# --- <semantic-card id="executor_routing_launches_task_execution_run"> ---
# kind: routing-relation
# fpf_basis:
#   - C.Agent-Tools-CAL
# scope: BC.TaskWorld
# what: Links an approved routing decision to the execution run it launched.
# not: Not the task itself.
# why: Preserves routing-to-execution auditability.
relation executor_routing_launches_task_execution_run,
  relates executor_routing,
  relates launched_task_execution_run;
# --- </semantic-card> ---

# kind: context-relation
# fpf_basis:
#   - A.10 EvidenceGraph Referring
# scope: BC.TaskWorld
# what: Links a task to an object locator representing what should be changed.
# not: Not evidence and not acceptance.
# why: Makes object-of-application explicit without minting a second task companion entity.
relation task_targets_object_locator,
  relates task,
  relates object_locator;
# --- </semantic-card> ---

# --- <semantic-card id="task_cites_evidence_link"> ---
# kind: trace-relation
# fpf_basis:
#   - A.10 EvidenceGraph Referring
# scope: BC.TraceWorld
# what: Links a task to normalized quoted evidence.
# not: Not the discussion relation itself.
# why: Keeps evidence explicit as part of the task-local execution surface.
relation task_cites_evidence_link,
  relates task,
  relates evidence_link;
# --- </semantic-card> ---


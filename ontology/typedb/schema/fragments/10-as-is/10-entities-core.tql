# ==============================
# Entities
# ==============================

# --- <semantic-card id="client"> ---
# kind: party-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational customer/client owner record.
# not: Not a project and not a project context card.
# why: Captures current ownership-side project metadata in AS-IS runtime.
entity client,
  owns client_id @key,
  owns name,
  owns activity_state @values("active", "inactive", "unknown"),
  owns project_groups_ids,
  owns created_at,
  owns updated_at,
  plays client_owns_project:owner_client,
  plays client_has_project_group:owner_client;
# --- </semantic-card> ---

# --- <semantic-card id="legacy_client"> ---
# kind: legacy-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Legacy client record kept for historical/runtime compatibility.
# not: Not canonical customer truth.
# why: Preserves legacy references during AS-IS ingestion.
entity legacy_client,
  owns legacy_client_id @key,
  owns name,
  owns activity_state @values("active", "inactive", "unknown"),
  owns drive_folder_id,
  owns project_groups_ids;
# --- </semantic-card> ---

# --- <semantic-card id="project_group"> ---
# kind: group-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational grouping record for projects.
# not: Not a project itself.
# why: Captures current grouping semantics from runtime systems.
entity project_group,
  owns project_group_id @key,
  owns name,
  owns activity_state @values("active", "inactive", "unknown"),
  owns project_groups_ids,
  owns client_id,
  owns created_at,
  owns updated_at,
  plays client_has_project_group:owned_project_group,
  plays project_group_has_project:project_group;
# --- </semantic-card> ---

# --- <semantic-card id="project"> ---
# kind: operational-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational project record from Mongo runtime.
# not: Not the target project semantic surface.
# why: Acts as the AS-IS source projected into project_context_card.
entity project,
  owns project_id @key,
  owns name,
  owns activity_state @values("active", "inactive", "unknown"),
  owns project_group_ref,
  owns board_id,
  owns description,
  owns git_repo,
  owns drive_folder_id,
  owns figma_project_link,
  owns design_files,
  owns start_date,
  owns end_date,
  owns merged_at,
  owns merged_into_project_id,
  owns created_at,
  owns updated_at,
  owns module_scope,
  owns runtime_tag,
  plays client_owns_project:owned_project,
  plays project_group_has_project:linked_project,
  plays project_has_project_link:owner_project,
  plays project_has_task:owner_project,
  plays project_has_voice_session:owner_project,
  plays project_has_epic_task:owner_project,
  plays project_has_google_drive_file:owner_project,
  plays project_has_voice_topic:owner_project,
  plays project_has_telegram_chat_source:owner_project,
  plays project_has_legacy_finance_income:owner_project,
  plays project_has_fact_month:owner_project,
  plays project_has_forecast_month:owner_project,
  plays project_has_cost_expense:owner_project,
  plays project_has_agent_request:owner_project,
  plays project_has_kpi:owner_project,
  plays project_performer_link_binds_project:bound_project,
  plays project_context_card_describes_project:described_project,
  plays artifact_record_supports_project:supported_project,
  plays context_bundle_assembles_project:assembled_project,
  plays as_is_project_maps_to_project_context_card:as_is_project;
# --- </semantic-card> ---

# --- <semantic-card id="project_link"> ---
# kind: link-record
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ProjectWorld
# what: Operational project link/reference record.
# not: Not the project itself.
# why: Keeps external references attached to projects in AS-IS.
entity project_link,
  owns project_link_id @key,
  owns source_type,
  owns url,
  owns link_label,
  plays project_has_project_link:linked_project_link;
# --- </semantic-card> ---

# --- <semantic-card id="person"> ---
# kind: party-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational person/contact/participant record.
# not: Not the internal performer profile with permissions, auth, and payroll fields.
# why: Captures generic human/contact semantics and links to performer_profile when the person is an internal performer.
entity person,
  owns person_id @key,
  owns name,
  owns contacts_payload,
  owns project_participations,
  owns performer_id,
  owns created_at,
  owns updated_at,
  plays transcript_segment_spoken_by_person:speaker_person,
  plays voice_session_has_participant_person:participant_person,
  plays person_has_performer_profile:person,
  plays telegram_user_maps_to_person:linked_person;
# --- </semantic-card> ---

# --- <semantic-card id="performer_profile"> ---
# kind: operational-record
# fpf_basis:
#   - A.2 Role Taxonomy
#   - A.2.1 U.RoleAssignment
# scope: BC.ProjectWorld
# what: Internal performer/staff profile used for permissions, payroll, assignment, and auth-linked operational flows.
# not: Not a generic contact/person row.
# why: Separates internal performer semantics from broader person/contact semantics while preserving explicit linkage.
entity performer_profile,
  owns performer_profile_id @key,
  owns name,
  owns external_id,
  owns role_name @values("PERFORMER", "SUPER_ADMIN", "MANAGER", "VIEWER", "UNKNOWN"),
  owns additional_roles,
  owns corporate_email,
  owns board_url,
  owns is_active,
  owns is_active_legacy,
  owns is_banned,
  owns is_deleted,
  owns is_employee,
  owns monthly_salary,
  owns monthly_payment,
  owns salary_currency @values("RUB", "UNKNOWN"),
  owns monthly_salary_by_month,
  owns projects_access,
  owns custom_permissions,
  owns password_hash,
  owns password_updated_at,
  owns permissions_updated_at,
  owns drive_folder_id,
  owns google_drive_name,
  owns telegram_user_id,
  owns telegram_name,
  owns notifications,
  owns payments_settings,
  plays person_has_performer_profile:performer_profile,
  plays telegram_user_maps_to_performer_profile:linked_performer_profile,
  plays task_assigned_to_performer_profile:assignee_performer_profile,
  plays performer_profile_enacts_executor_role:performer_profile,
  plays project_performer_link_binds_performer_profile:linked_performer_profile,
  plays performer_profile_maps_to_employee:source_performer_profile,
  plays performer_profile_creates_work_log:author_performer_profile,
  plays performer_profile_has_legacy_finance_expense:performer_profile,
  plays performer_profile_has_legacy_finance_income:performer_profile;
# --- </semantic-card> ---

# --- <semantic-card id="telegram_chat"> ---
# kind: operational-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational Telegram group/source chat attached to projects and performers.
# not: Not a direct-message session and not a voice session.
# why: Preserves first-class project_chat / performer_chat / design-chat routing sources in AS-IS.
entity telegram_chat,
  owns telegram_chat_id @key,
  owns chat_name,
  owns chat_type,
  owns source_kind @values("project_chat", "performer_chat", "general_design_chat", "unknown"),
  owns directives,
  owns linked_project_ids,
  owns is_active,
  owns created_at,
  owns updated_at,
  plays project_has_telegram_chat_source:source_chat,
  plays telegram_chat_has_member:telegram_chat;
# --- </semantic-card> ---

# --- <semantic-card id="telegram_user"> ---
# kind: operational-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational Telegram user/contact record linked to person and/or performer profile.
# not: Not a generic person row and not a chat itself.
# why: Separates Telegram platform identity from internal performer profile while preserving linkage.
entity telegram_user,
  owns telegram_user_id @key,
  owns telegram_username,
  owns telegram_display_name,
  owns performer_id,
  owns person_id,
  owns is_active,
  owns created_at,
  owns updated_at,
  plays telegram_chat_has_member:telegram_user,
  plays telegram_user_maps_to_person:telegram_user,
  plays telegram_user_maps_to_performer_profile:telegram_user;
# --- </semantic-card> ---

# --- <semantic-card id="project_performer_link"> ---
# kind: operational-record
# fpf_basis:
#   - A.2.1 U.RoleAssignment
# scope: BC.ProjectWorld
# what: Canonical temporal many-to-many relation record between project and performer.
# not: Not permissions/access payload and not a generic person participation field.
# why: Holds the authoritative project membership window used by runtime and ontology projection.
entity project_performer_link,
  owns project_performer_link_id @key,
  owns project_id,
  owns performer_id,
  owns person_id,
  owns membership_role,
  owns source,
  owns confidence,
  owns start_date,
  owns end_date,
  owns is_active,
  owns created_at,
  owns updated_at,
  plays project_performer_link_binds_project:project_performer_link,
  plays project_performer_link_binds_performer_profile:project_performer_link;
# --- </semantic-card> ---

# --- <semantic-card id="team"> ---
# kind: group-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational team record.
# not: Not a person or role assignment.
# why: Represents current team grouping in AS-IS.
entity team,
  owns team_id @key,
  owns name,
  owns status;
# --- </semantic-card> ---

# --- <semantic-card id="role_dict"> ---
# kind: dictionary-record
# fpf_basis:
#   - A.2 Role Taxonomy
# scope: BC.AgentWorld
# what: Operational role dictionary entry.
# not: Not a role assignment instance.
# why: Provides current role labels used by runtime systems.
entity role_dict,
  owns role_id @key,
  owns name,
  owns status;
# --- </semantic-card> ---

# --- <semantic-card id="status_dict"> ---
# kind: dictionary-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Operational status dictionary entry.
# not: Not a task state transition event.
# why: Provides AS-IS status vocabulary.
entity status_dict,
  owns status_id @key,
  owns name,
  owns module_scope,
  owns order_index,
  plays task_has_status:task_status;
# --- </semantic-card> ---

# --- <semantic-card id="priority_dict"> ---
# kind: dictionary-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Operational priority dictionary entry.
# not: Not a ranking decision.
# why: Provides AS-IS priority vocabulary.
entity priority_dict,
  owns priority_id @key,
  owns name,
  owns priority_rank,
  plays task_has_priority:task_priority;
# --- </semantic-card> ---

# --- <semantic-card id="task_type"> ---
# kind: dictionary-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Operational task type dictionary entry.
# not: Not a task instance.
# why: Provides AS-IS task classification vocabulary.
entity task_type,
  owns task_type_id @key,
  owns name,
  plays task_classified_as_task_type:task_type;
# --- </semantic-card> ---

# --- <semantic-card id="task_type_tree"> ---
# kind: taxonomy-record
# fpf_basis:
#   - U.BoundedContext
#   - A.6.5 U.RelationSlotDiscipline
# scope: BC.TaskWorld
# what: Operational task taxonomy/tree node.
# not: Not a task view.
# why: Captures current type hierarchy and planning metadata.
entity task_type_tree,
  owns task_type_tree_id @key,
  owns title,
  owns description,
  owns type_class @values("TASK", "FUNCTIONALITY", "UNKNOWN"),
  owns execution_plan,
  owns roles,
  owns parent_type_id,
  owns task_id,
  plays task_type_tree_classifies_task:task_type_tree;
# --- </semantic-card> ---

# --- <semantic-card id="voice_context_item"> ---
# kind: evidence-record
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.VoiceWorld
# what: Operational voice context item extracted from communication.
# not: Not a target context bundle.
# why: Preserves current evidence/context artifacts in AS-IS.
entity voice_context_item,
  owns context_item_id @key,
  owns project_id,
  owns source_type,
  owns title,
  owns summary,
  owns created_at,
  plays project_has_voice_context_item:context_item,
  plays dialog_represented_by_context_item:context_item,
  plays agreement_evidenced_by_context_item:context_item,
  plays task_evidenced_by_context_item:context_item;
# --- </semantic-card> ---

# --- <semantic-card id="dialog"> ---
# kind: interaction-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.VoiceWorld
# what: Operational dialog record.
# not: Not a mode segment.
# why: Represents dialog-level AS-IS structure.
entity dialog,
  owns dialog_id @key,
  owns project_id,
  owns started_at,
  owns ended_at,
  plays dialog_represented_by_context_item:dialog,
  plays dialog_has_transcript_segment:dialog,
  plays dialog_yields_agreement:dialog;
# --- </semantic-card> ---

# --- <semantic-card id="transcript_segment"> ---
# kind: evidence-record
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.VoiceWorld
# what: Operational transcript segment.
# not: Not a normalized object event.
# why: Preserves AS-IS transcript evidence.
entity transcript_segment,
  owns segment_id @key,
  owns summary,
  owns started_at,
  owns ended_at,
  owns started_at_seconds,
  owns ended_at_seconds,
  plays dialog_has_transcript_segment:segment,
  plays voice_transcription_has_transcript_segment:transcript_segment,
  plays transcript_segment_spoken_by_person:segment;
# --- </semantic-card> ---

# --- <semantic-card id="agreement"> ---
# kind: decision-record
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.TaskWorld
# what: Operational agreement/decision record.
# not: Not a target task or project card.
# why: Captures AS-IS agreement outcomes from dialogs.
entity agreement,
  owns agreement_id @key,
  owns project_id,
  owns title,
  owns summary,
  owns status,
  owns decided_at,
  plays dialog_yields_agreement:agreement,
  plays agreement_evidenced_by_context_item:agreement,
  plays agreement_creates_task:agreement;
# --- </semantic-card> ---

# --- <semantic-card id="task"> ---
# kind: task-record
# fpf_basis:
#   - U.BoundedContext
#   - A.6.5 U.RelationSlotDiscipline
# scope: BC.TaskWorld
# what: Operational task record from Mongo runtime.
# not: Not the normalized target task view.
# why: Acts as the main AS-IS source for task projection.
# field task_id: canonical Mongo document identity for the task row.
# field project_id: owning project identifier used for project/task binding.
# field external_id: public or external-facing task identifier when present.
# field old_id: legacy historical task identifier kept for compatibility.
# field project_ref: raw project reference text copied from runtime payloads.
# field row_id: canonical row locator for draft/task reconcile and dedupe.
# field type_class: coarse task class used by runtime grouping and logic.
# field title: primary human-readable task title.
# field description: main task body/acceptance-oriented formulation text.
# field status: stored task lifecycle label as persisted in Mongo.
# field last_status: previous stored lifecycle label when runtime tracks transitions.
# field last_status_update: timestamp of latest lifecycle change.
# field status_history: legacy/general status history payload.
# field task_status_history: task-specific lifecycle transition history payload.
# field priority: stored task priority label/value.
# field due_at: planned due date or deadline timestamp.
# field priority_rank: numeric priority rank for sorting/comparison.
# field task_type_name: raw human-readable task type label.
# field task_type_id: referenced task-type dictionary identifier.
# field sprint: sprint/batch label when task is assigned to one.
# field shipment_date: planned shipment/release date when tracked.
# field score_min_hours: lower effort estimate bound in hours.
# field score_max_hours: upper effort estimate bound in hours.
# field planned_time: explicit planned effort budget.
# field performer: raw performer display label.
# field performer_id: performer profile identifier responsible for execution.
# field epic_task_id: parent epic identifier when task belongs to one.
# field notion_url: linked Notion artifact URL when present.
# field notion_board_id: linked Notion board identifier when present.
# field status_update_checked: runtime marker that status-sync/check pass was completed.
# field comments_list: embedded legacy comments payload.
# field dashboard_comment: compact dashboard-specific comment text.
# field order_index: manual/display ordering index.
# field source: source system/family marker for lineage.
# field source_kind: provenance subtype such as voice/session origin marker.
# field source_ref: primary source reference used for task/session lineage joins.
# field external_ref: secondary external source reference used for lineage joins.
# field source_data: raw structured lineage/context payload kept for compatibility.
# field parent_id: scalar parent task locator retained alongside richer parent relation payloads.
# field dialogue_reference: quoted transcript/dialogue fragment explaining why task exists.
# field dialogue_tag: analyzer/runtime tag for discussion slice or task class.
# field dependencies: normalized dependency payload.
# field dependencies_from_ai: analyzer-emitted dependency identifiers.
# field labels: freeform labels/tags attached to the task.
# field notes: extra operator/runtime notes bound to the task.
# field issue_type: issue/task subtype label when runtime provides one.
# field assignee: raw assignee label kept for compatibility.
# field owner: raw owner label kept for compatibility.
# field created_by: creator identifier.
# field created_by_name: creator display name.
# field created_by_performer_id: creator performer-profile identifier.
# field task_id_from_ai: analyzer-emitted task identifier used as compatibility metadata.
# field priority_reason: explanation of why the chosen priority was assigned.
# field codex_task: marks the row as a Codex-issued taskflow row.
# field codex_review_state: deferred-review lifecycle marker for Codex flow.
# field codex_review_due_at: next due timestamp for Codex review handling.
# field codex_review_summary: generated Codex review summary text.
# field codex_review_summary_source: provenance of the summary content.
# field codex_review_summary_issue_id: linked issue identifier for review summary lineage.
# field codex_review_summary_processing: processing-state marker for review summary generation.
# field codex_review_summary_attempts: retry counter for summary generation.
# field codex_review_summary_job_id: async job identifier for summary generation.
# field codex_review_summary_started_at: summary generation start timestamp.
# field codex_review_summary_generated_at: summary generation completion timestamp.
# field codex_review_summary_next_attempt_at: scheduled next retry timestamp.
# field codex_review_summary_last_error_code: latest review-summary error code.
# field codex_review_summary_last_error_message: latest review-summary error message.
# field codex_review_summary_last_runner_error: latest runner-level error payload.
# field codex_review_summary_last_error_at: timestamp of latest summary-generation error.
# field codex_review_summary_finished_at: terminal timestamp for summary pipeline.
# field codex_review_summary_note_marker: marker used when syncing summary note back.
# field codex_review_summary_note_synced_at: timestamp when summary note sync completed.
# field codex_review_summary_note_appended: flag that summary note append happened.
# field codex_review_approval_card_sent_at: timestamp when approval card was sent.
# field codex_review_approval_card_chat_id: target chat identifier for approval card.
# field codex_review_approval_card_thread_id: target thread/topic identifier for approval card.
# field codex_review_approval_card_message_id: sent approval card message identifier.
# field codex_review_approval_card_start_callback: callback token for approval start action.
# field codex_review_approval_card_cancel_callback: callback token for approval cancel action.
# field runtime_tag: legacy runtime isolation tag kept for compatibility/transition.
# field is_deleted: soft-delete flag.
# field deleted_at: soft-delete timestamp when the task leaves the active runtime surface.
# field stop_comment_parsing: flag disabling automatic comment parsing for this task.
# field created_at: creation timestamp.
# field updated_at: last update timestamp.
entity task,
  # canonical Mongo row identity from automation_tasks._id
  owns task_id @key,
  # bound project identifier used by task/project routing and reporting
  owns project_id,
  # public/external task id shown in UI when present
  owns external_id,
  # older legacy task id retained for historical compatibility
  owns old_id,
  # legacy project label fallback from raw task rows
  owns project_ref,
  # canonical draft/taskflow row locator reused across refreshes
  owns row_id,
  # broad class of work (task/spec/research/etc) used by runtime prompts and UI
  owns type_class,
  # primary task title / short actionable name
  owns title,
  # main task body / execution description
  owns description,
  # canonical lifecycle key projected from raw Mongo task_status
  owns status @values("DRAFT_10", "READY_10", "PROGRESS_10", "REVIEW_10", "DONE_10", "ARCHIVE", "UNKNOWN"),
  # previous stored lifecycle label when tracked separately
  owns last_status,
  # timestamp of the latest lifecycle change
  owns last_status_update,
  # legacy status-history payload from raw storage
  owns status_history,
  # structured lifecycle transition history payload
  owns task_status_history,
  # raw priority label/value from runtime task rows
  owns priority @values("P1", "P2", "P3", "P4", "P5", "P6", "P7", "UNKNOWN"),
  # task deadline / due timestamp
  owns due_at,
  # normalized numeric priority rank when available
  owns priority_rank,
  # legacy task-type label from raw rows
  owns task_type_name,
  # canonical task-type dictionary id
  owns task_type_id,
  # sprint label/id used by planning surfaces
  owns sprint,
  # planned shipment/delivery date
  owns shipment_date,
  # lower estimate bound in hours
  owns score_min_hours,
  # upper estimate bound in hours
  owns score_max_hours,
  # explicit planned work time in hours
  owns planned_time,
  # legacy assignee label/name from raw task rows
  owns performer,
  # canonical performer profile id used for assignment
  owns performer_id,
  # linked epic identifier when the task belongs to an epic
  owns epic_task_id,
  # external Notion page URL for the task
  owns notion_url,
  # external Notion board/database id
  owns notion_board_id,
  # runtime flag that status update was explicitly reviewed/acknowledged
  owns status_update_checked,
  # embedded/historical comments cache mirrored on the task row
  owns comments_list,
  # dashboard-facing summary/comment field
  owns dashboard_comment,
  # kanban/manual ordering index
  owns order_index,
  # producing subsystem label (VOICE_BOT, etc)
  owns source,
  # provenance kind such as voice_possible_task or voice_session
  owns source_kind @values("voice_possible_task", "voice_session", "unknown"),
  # primary source/session reference used for lineage
  owns source_ref,
  # external canonical source reference used by session/task joins
  owns external_ref,
  # normalized JSON payload with lineage and compatibility metadata
  owns source_data,
  # scalar parent task locator mirrored from richer parent relation payloads
  owns parent_id,
  # transcript excerpt / phrase that evidences why the task exists
  owns dialogue_reference,
  # dialogue/task tag used by voice taskflow
  owns dialogue_tag @values("voice", "chat", "doc", "call", "UNKNOWN"),
  # structured dependency payload from storage/runtime
  owns dependencies,
  # dependency ids suggested by AI extraction
  owns dependencies_from_ai,
  # freeform labels/tags attached to the task
  owns labels,
  # extra notes not normalized into stronger fields
  owns notes,
  # issue category/classification for mixed task/issue surfaces
  owns issue_type,
  # legacy assignee label retained for compatibility
  owns assignee,
  # owner label/id retained from raw task rows
  owns owner,
  # creator id
  owns created_by,
  # creator display name
  owns created_by_name,
  # creator performer profile id
  owns created_by_performer_id,
  # AI-generated stable candidate id used as fallback locator
  owns task_id_from_ai,
  # rationale for assigned priority
  owns priority_reason,
  # marks Codex-managed taskflow rows
  owns codex_task,
  # current Codex deferred-review state
  owns codex_review_state,
  # due-at for deferred Codex review
  owns codex_review_due_at,
  # generated Codex review summary text
  owns codex_review_summary,
  # source label of the generated review summary
  owns codex_review_summary_source,
  # linked issue/task id mentioned by review summary
  owns codex_review_summary_issue_id,
  # processing flag for review summary generation
  owns codex_review_summary_processing,
  # retry attempt counter for review summary generation
  owns codex_review_summary_attempts,
  # background job id for summary generation
  owns codex_review_summary_job_id,
  # timestamp when summary generation started
  owns codex_review_summary_started_at,
  # timestamp when summary was generated
  owns codex_review_summary_generated_at,
  # next retry timestamp for deferred summary generation
  owns codex_review_summary_next_attempt_at,
  # last structured error code from summary generation
  owns codex_review_summary_last_error_code,
  # last human-readable error message from summary generation
  owns codex_review_summary_last_error_message,
  # last runner/internal error payload
  owns codex_review_summary_last_runner_error,
  # timestamp of last summary-generation error
  owns codex_review_summary_last_error_at,
  # timestamp when summary generation finished
  owns codex_review_summary_finished_at,
  # marker showing whether review note was appended
  owns codex_review_summary_note_marker,
  # timestamp when review note sync completed
  owns codex_review_summary_note_synced_at,
  # flag whether review note append succeeded
  owns codex_review_summary_note_appended,
  # timestamp when approval card was sent
  owns codex_review_approval_card_sent_at,
  # Telegram chat id for approval card delivery
  owns codex_review_approval_card_chat_id,
  # Telegram thread/topic id for approval card delivery
  owns codex_review_approval_card_thread_id,
  # Telegram message id of the approval card
  owns codex_review_approval_card_message_id,
  # callback token/action for approval-card start
  owns codex_review_approval_card_start_callback,
  # callback token/action for approval-card cancel
  owns codex_review_approval_card_cancel_callback,
  # legacy runtime family marker kept for historical rows only
  owns runtime_tag,
  # soft-delete flag
  owns is_deleted,
  # timestamp when the row was soft-deleted
  owns deleted_at,
  # legacy flag that comment parsing should stop for this task
  owns stop_comment_parsing,
  # creation timestamp
  owns created_at,
  # last update timestamp
  owns updated_at,
  plays project_has_task:task,
  plays voice_session_sources_task:sourced_task,
  plays task_classified_as_task_type:task,
  plays task_type_tree_classifies_task:task,
  plays task_has_work_log:task,
  plays agreement_creates_task:task,
  plays task_evidenced_by_context_item:task,
  plays task_has_status:task,
  plays task_has_priority:task,
  plays task_assigned_to_performer_profile:task,
  plays patch_operation_mutates_task:task,
  plays task_changes_system_of_interest:task,
  plays task_executed_by_producing_system:task,
  plays goal_process_decomposes_to_task:task,
  plays task_satisfies_requirement:task,
  plays task_must_satisfy_acceptance_criterion:task,
  plays task_classified_as_task_family:task,
  plays executor_routing_targets_task:routed_task,
  plays task_execution_run_executes_task:executed_task,
  plays task_targets_object_locator:task,
  plays task_cites_evidence_link:task,
  plays task_recommended_for_coding_agent:task,
  plays task_produces_artifact_record:task,
  plays object_revision_revises_task:revised_task,
  plays object_event_affects_task:affected_task,
  plays object_note_attaches_to_task:noted_task,
  plays object_conclusion_applies_to_task:concluded_task,
  plays change_proposal_targets_task:proposed_task,
  plays assumption_conditions_task:conditioned_task,
  plays open_question_blocks_task:blocked_task;
# --- </semantic-card> ---

# --- <semantic-card id="epic_task"> ---
# kind: task-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.TaskWorld
# what: Operational epic task record.
# not: Not a target task view.
# why: Preserves current epic/task hierarchy in AS-IS.
entity epic_task,
  owns epic_task_id @key,
  owns project_id,
  owns name,
  owns description,
  owns is_deleted,
  owns created_at,
  plays project_has_epic_task:epic_task;
# --- </semantic-card> ---

# --- <semantic-card id="work_log"> ---
# kind: history-record
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.TaskWorld
# what: Operational work-log entry.
# not: Not a task record.
# why: Captures current execution history attached to tasks.
entity work_log,
  owns work_log_id @key,
  owns ticket_id,
  owns ticket_db_id,
  owns created_by,
  owns date,
  owns date_timestamp,
  owns comment,
  owns comment_id,
  owns description,
  owns work_hours,
  owns created_at,
  owns edited_at,
  owns raw_date,
  owns result_link,
  plays task_has_work_log:work_log,
  plays performer_profile_creates_work_log:work_log;
# --- </semantic-card> ---

# --- <semantic-card id="agent"> ---
# kind: runtime-agent-record
# fpf_basis:
#   - A.2 Role Taxonomy
#   - C.Agent-Tools-CAL
# scope: BC.AgentWorld
# what: Operational agent record.
# not: Not the target agent_role.
# why: Represents current runtime agents and identifiers.
entity agent,
  owns agent_id @key,
  owns name,
  owns module_scope,
  owns status,
  plays execution_job_executed_by_agent:agent,
  plays recommendation_authored_by_agent:agent;
# --- </semantic-card> ---

# --- <semantic-card id="execution_job"> ---
# kind: runtime-execution-record
# fpf_basis:
#   - C.Agent-Tools-CAL
# scope: BC.AgentWorld
# what: Operational execution job record.
# not: Not a prompt pipeline.
# why: Captures current runtime execution state.
entity execution_job,
  owns external_id @key,
  owns status,
  owns started_at,
  owns ended_at,
  plays execution_job_executed_by_agent:execution_job;
# --- </semantic-card> ---

# --- <semantic-card id="result_artifact"> ---
# kind: artifact-record
# fpf_basis:
#   - E.17 U.MultiViewDescribing
# scope: BC.ArtifactWorld
# what: Operational result artifact record.
# not: Not the TO-BE artifact_record.
# why: Preserves existing artifact outputs during projection.
entity result_artifact,
  owns external_id @key,
  owns source_type,
  owns url,
  owns created_at;
# --- </semantic-card> ---

# --- <semantic-card id="kpi"> ---
# kind: metric-record
# fpf_basis:
#   - U.BoundedContext
# scope: BC.ProjectWorld
# what: Operational KPI record.
# not: Not an observation event.
# why: Captures current KPI definitions.
entity kpi,
  owns external_id @key,
  owns module_name,
  owns name,
  owns description,
  plays project_has_kpi:kpi,
  plays kpi_observed_as_observation:kpi;
# --- </semantic-card> ---

# --- <semantic-card id="kpi_observation"> ---
# kind: metric-observation-record
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.ProjectWorld
# what: Operational KPI observation.
# not: Not the KPI definition.
# why: Captures observed KPI values/events.
entity kpi_observation,
  owns external_id @key,
  owns project_id,
  owns value_number,
  owns created_at,
  plays kpi_observed_as_observation:kpi_observation,
  plays kpi_observation_fires_trigger_event:kpi_observation;
# --- </semantic-card> ---

# --- <semantic-card id="kpi_trigger_event"> ---
# kind: trigger-record
# fpf_basis:
#   - A.2.9 U.SpeechAct
# scope: BC.ProjectWorld
# what: Operational trigger event derived from KPI observation.
# not: Not a recommendation.
# why: Represents current eventing logic in AS-IS.
entity kpi_trigger_event,
  owns external_id @key,
  owns severity,
  owns summary,
  owns created_at,
  plays kpi_observation_fires_trigger_event:trigger_event,
  plays trigger_event_emits_recommendation:trigger_event;
# --- </semantic-card> ---

# --- <semantic-card id="recommendation"> ---
# kind: recommendation-record
# fpf_basis:
#   - A.2.3 U.PromiseContent
# scope: BC.ProjectWorld
# what: Operational recommendation artifact.
# not: Not a commitment or output contract.
# why: Captures current recommendation outputs in AS-IS.
entity recommendation,
  owns external_id @key,
  owns summary,
  owns description,
  owns status,
  owns created_at,
  plays trigger_event_emits_recommendation:recommendation,
  plays recommendation_authored_by_agent:recommendation;
# --- </semantic-card> ---
